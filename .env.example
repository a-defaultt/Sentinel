# NVIDIA Build API (Free Tier: One key per model)
NVIDIA_PRIMARY_KEY=your_primary_model_key_here
NVIDIA_FALLBACK_KEY=your_fallback_model_key_here
NVIDIA_EMBEDDING_KEY=your_embedding_model_key_here
NVIDIA_RERANKING_KEY=your_reranking_model_key_here
NVIDIA_TIMEOUT_SECONDS=45

# Threat Intelligence
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=sentinel@yourdomain.com
SMTP_TO=soc-team@yourdomain.com

# Webhook Configuration
WEBHOOK_URL=https://your-webhook-endpoint.com/alerts

# Paths
DATA_DIR=/app/data
CHROMA_DATA_PATH=/app/chroma_data
ALERTS_JSON_PATH=/app/data/alerts.json

# Logging
LOG_LEVEL=INFO
